# Runtime artifacts (CSL UX app)
# Solver decks + outputs written into the sim dir during a Run
*.wam
*AVG.DAT
*INS.DAT
intake.vlv
exhaust.vlv
log_*.txt

# Phase-A RunStore (local SQLite data lake) — runtime data, not source
backend/app/data/runs.db
backend/app/data/runs.db-shm
backend/app/data/runs.db-wal

# Deterministic deck/result cache
.sim_cache/

# Persisted run results (recovery cache written on completion by
# run_ve_map_generation / optimize_wot — GET /simulate/last reads these; they
# are regenerated by any run, so they are runtime state, not source).
backend/app/data/last_run_*.json

# Uploaded ECU binary (runtime upload target for /binary/upload)
backend/app/data/uploaded_mss54.bin

# Runtime error log
backend/error_log.txt
